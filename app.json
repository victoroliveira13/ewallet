{
  "expo": {
    "name": "E-Wallet",
    "slug": "ewallet-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0E18"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ewallet.app",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ewallet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0D0E18"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00D97E",
          "defaultChannel": "ewallet"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir que o eWallet use o Face ID para autenticar."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "081c24f3-9bdc-47e1-9d12-5585c42223b8"
      }
    },
    "owner": "victor12321"
  }
}
